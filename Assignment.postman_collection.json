    {
      "name": "Validate user is able to post an object successfully",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect([",
              "        200,",
              "        201",
              "    ]).to.include(pm.response.code);",
              "})",
              "",
              "pm.test('Response time is under 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "})",
              "",
              "pm.test('Response body is JSON', function () {",
              "    pm.response.to.be.json;",
              "})",
              "",
              "pm.test('Response body has id and name', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an('object');",
              "    pm.expect(responseJson).to.have.property('id');",
              "    pm.expect(responseJson).to.have.property('name');",
              "})",
              "",
              "pm.test('Response body name matches request body name', function () {",
              "    let expectedName;",
              "    const raw = pm.request.body && pm.request.body.mode === 'raw' ? pm.request.body.raw : null;",
              "    if (raw) {",
              "        try {",
              "            const parsed = JSON.parse(raw);",
              "            expectedName = parsed && parsed.name;",
              "        } catch (e) {",
              "        }",
              "    }",
              "    if (expectedName === undefined && pm.request.body && (pm.request.body.mode === 'formdata' || pm.request.body.mode === 'urlencoded')) {",
              "        const arr = pm.request.body[pm.request.body.mode] || [];",
              "        const item = arr.find(i => i && i.key === 'name' && i.disabled !== true);",
              "        expectedName = item && item.value;",
              "    }",
              "    pm.expect(expectedName, 'Request body must include a \\'name\\'').to.not.be.undefined;",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.have.property('name');",
              "    pm.expect(responseJson.name).to.eql(expectedName);",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
